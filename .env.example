# 小宇宙播客转文字 - 环境配置模板
# 复制此文件为 .env 并填入你的配置

# Whisper 模型配置
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# 火山引擎 DeepSeek API (加密存储)
# 1. 获取你的 API Key
# 2. 运行: python -m utils.encryption "your-api-key-here"
# 3. 将输出的加密字符串填入下方
VOLCENGINE_API_KEY_ENC=your-encrypted-api-key-here
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL_NAME=deepseek-v3

# 可选：自定义主密钥（增强安全性）
# 如果不设置，将使用默认开发密钥
# MASTER_KEY=your-secret-master-key-32bytes-long

# 应用配置
APP_NAME=Audio Transcriber API
APP_VERSION=2.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
TEMP_DIR=temp
LOG_LEVEL=INFO
